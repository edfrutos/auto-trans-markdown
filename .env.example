# Clave API (OpenAI o compatible: Azure, Ollama, etc.)
OPENAI_API_KEY=sk-your-key-here

# Opcional: endpoint compatible con OpenAI (ej. http://localhost:11434/v1)
# OPENAI_BASE_URL=

# Modelo (por defecto gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Proveedor: openai (default) o deepl
# TRANSLATION_PROVIDER=openai
# DEEPL_API_KEY=
# DEEPL_API_URL=

# Si provider=deepl falla (cuota/idioma), reintentar con OpenAI si hay OPENAI_API_KEY
# TRANSLATION_FALLBACK=openai

# Servidor
HOST=127.0.0.1
PORT=5400

# Umbral USD para aviso de coste estimado (COST-02 backend flag)
ESTIMATE_WARN_USD=1.0

# Despliegue / seguridad (SEC-01, SEC-02)
# Orígenes CORS separados por coma (default: localhost:5400)
# CORS_ORIGINS=http://127.0.0.1:5400,http://localhost:5400
# CORS_ORIGINS=*

# Límites de subida (MB)
# MAX_UPLOAD_MB=10
# MAX_BATCH_UPLOAD_MB=50

# Limpieza de archivos temporales en output/
# OUTPUT_TTL_HOURS=24
# OUTPUT_SWEEP_INTERVAL_HOURS=6

# Token Bearer opcional para proteger /api/translate*
# API_TOKEN=
